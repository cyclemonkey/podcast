# ── Authentik OAuth2/OIDC configuration ──────────────────────────────────────
#
# Copy these variables into your app's environment.
# In Coolify: app → Environment Variables tab.
# Mark AUTHENTIK_CLIENT_SECRET and SESSION_SECRET as "secret" (sensitive).
#
# All four AUTHENTIK_* vars must be set to enable authentication.
# If any are absent the app falls back to anonymous session (useful locally).
#
# See README.md for full setup instructions.

# Base URL of your Authentik instance (no trailing slash)
AUTHENTIK_URL=https://auth.yourdomain.com

# OAuth2 Client ID — from Authentik: Applications → Providers → your provider
AUTHENTIK_CLIENT_ID=your-client-id-here

# OAuth2 Client Secret — from Authentik: Applications → Providers → your provider
# Keep this secret. Never commit the real value to version control.
AUTHENTIK_CLIENT_SECRET=your-client-secret-here

# Application slug — from Authentik: Applications → Applications → your app → Slug field
AUTHENTIK_SLUG=your-app-slug

# ── Application URL ───────────────────────────────────────────────────────────

# Public URL of THIS app (no trailing slash). Used to build the OAuth callback URI.
# The callback URI registered in Authentik must be: APP_URL + /auth/callback
APP_URL=https://myapp.yourdomain.com

# ── Session security ──────────────────────────────────────────────────────────

# Secret key for signing session cookies. Generate a strong random value:
#   openssl rand -hex 32
# Keep this secret. Rotating it will invalidate all existing sessions.
SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated list of Authentik usernames that have admin/elevated access.
# If empty, all authenticated users are treated as admins (fine for solo use).
# ADMIN_USERS=alice,bob
